---
import type { LexicalContent } from './render';
import { renderLexical } from './render';

export interface Props {
  content: LexicalContent | null | undefined;
  class?: string;
}

const { content, class: className = '' } = Astro.props;
const _html = renderLexical(content);

const _classes = ['richtext', className].filter(Boolean).join(' ');
---

{_html ? (
  <div class={_classes} set:html={_html} />
) : (
  <slot />
)}