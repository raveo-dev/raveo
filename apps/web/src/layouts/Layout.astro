---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  noIndex?: boolean;
  schema?: Record<string, unknown> | Record<string, unknown>[];
  canonical?: string;
}

const { title, description, noIndex, schema, canonical } = Astro.props;
const { navigation, siteSettings } = Astro.locals;

const _siteName = siteSettings?.siteName ?? 'Raveo';
const _siteDescription = description ?? siteSettings?.siteDescription ?? '';
const _canonicalUrl = canonical ?? Astro.url.href;
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={siteDescription} />
    <title>{title} — {siteName}</title>
    <link rel="canonical" href={canonicalUrl} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}
    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="color-scheme" content="light dark" />

    {/* FOUC prevention — reads cookie or system preference, applies .dark before first paint */}
    <script is:inline>
      (function () {
        var m = document.cookie.match(/(?:^|; )theme=(light|dark)/);
        var t = m ? m[1] : (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        if (t === 'dark') document.documentElement.classList.add('dark');
      })();
    </script>
  </head>
  <body class="min-h-screen bg-(--color-background) text-(--color-foreground) antialiased">
    <Header siteName={siteName} items={navigation?.items ?? []}>
      <ThemeToggle slot="actions" />
    </Header>

    <main class="max-w-6xl mx-auto px-4 py-8">
      <slot />
    </main>

    <Footer siteName={siteName} />
  </body>
</html>